# Copy this file to .env and fill in your values
# cp .env.example .env


# ── Database ───────────────────────────────────────────────────────────────────
 


# ── CORS (comma-separated) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://gridsense:gridsense@localhost:5433/gridsense
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Artifact directory ─────────────────────────────────────────────────────────
# Leave blank to use default (ml/artifacts/ relative to project root)
# ARTIFACT_DIR=/absolute/path/to/ml/artifacts

# ── Environment ────────────────────────────────────────────────────────────────
ENV=development

# ── Mock mode (set true if models not yet trained) ─────────────────────────────
MOCK_MODE=false
